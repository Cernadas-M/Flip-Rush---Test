        <script>
            (function() {
                const overlay = document.getElementById('gameOverlay');
                const wrap = document.getElementById('gameWrap');
                const loadingEl = document.getElementById('gameLoading');
                const playBtn = document.getElementById('playBtn');
                const mobileBtn = document.getElementById('mobileBtn');
                const heroImgBtn = document.getElementById('heroImgBtn');
                const closeBtn = document.getElementById('closeBtn');

                const GAME_ID = Number(document.querySelector('[data-game-id]')?.dataset?.gameId || 0);
                const USE_EMBED = wrap?.dataset?.useEmbed === 'true';
                const ALLOW_REFERRER = wrap?.dataset?.allowReferrer === '1';

                let lastAddedId = 0
                  , lastAddedAt = 0;
                let loaderHideTimer = null;
                let loaderSafetyTimer = null;
                let openToken = 0;

                function addRecentOnce(id) {
                    if (!Number.isInteger(id) || id <= 0)
                        return;
                    const now = Date.now();
                    if (id === lastAddedId && (now - lastAddedAt) < 1500)
                        return;
                    lastAddedId = id;
                    lastAddedAt = now;
                    if (window.BUBBLEBOXRecent?.add)
                        window.BUBBLEBOXRecent.add(id);
                }

                function showLoader() {
                    if (!loadingEl)
                        return;
                    loadingEl.classList.remove('is-hidden');
                    loadingEl.classList.add('is-visible');
                }

                function hideLoader() {
                    if (!loadingEl)
                        return;

                    loadingEl.classList.add('is-hidden');

                    clearTimeout(loaderHideTimer);
                    loaderHideTimer = setTimeout( () => {
                        loadingEl.classList.remove('is-visible', 'is-hidden');
                    }
                    , 240);
                }

                function clearLoaderTimers() {
                    clearTimeout(loaderHideTimer);
                    clearTimeout(loaderSafetyTimer);
                }

                function buildGameElement(url) {
                    let el;

                    if (USE_EMBED) {
                        el = document.createElement('embed');
                        el.src = url;
                        el.type = 'text/html';
                    } else {
                        el = document.createElement('iframe');
                        el.src = url;
                        el.title = 'Game';
                        el.loading = 'eager';
                        if (!ALLOW_REFERRER) {
                            el.referrerPolicy = 'no-referrer';
                        }
                        el.allowFullscreen = true;
                        el.setAttribute('allow', 'autoplay; fullscreen; gamepad; xr-spatial-tracking; clipboard-write');
                    }

                    Object.assign(el.style, {
                        border: '0',
                        width: '100%',
                        height: '100%',
                        display: 'block'
                    });

                    return el;
                }

                function openOverlay(fromBtn) {
                    const url = fromBtn?.dataset?.gameUrl || wrap.dataset.gameUrl;
                    const ext = fromBtn?.dataset?.externalUrl === 'true';
                    if (!url)
                        return false;

                    const isAbs = /^https?:\/\//i.test(url);
                    const sameOrigin = !isAbs || url.indexOf(location.origin) === 0;
                    if (!sameOrigin && ext) {
                        window.location.assign(url);
                        return false;
                    }

                    if (GAME_ID)
                        addRecentOnce(GAME_ID);

                    openToken += 1;
                    const myToken = openToken;

                    clearLoaderTimers();
                    wrap.replaceChildren();

                    document.documentElement.classList.add('no-scroll');
                    overlay.hidden = false;
                    showLoader();

                    closeBtn?.focus();
                    window.addEventListener('keydown', escClose);

                    // Let overlay + loader paint first, then create iframe
                    requestAnimationFrame( () => {
                        requestAnimationFrame( () => {
                            if (myToken !== openToken)
                                return;

                            const el = buildGameElement(url);
                            let loaderDone = false;

                            const done = () => {
                                if (loaderDone)
                                    return;
                                loaderDone = true;
                                hideLoader();
                            }
                            ;

                            el.addEventListener?.('load', () => {
                                setTimeout(done, 150);
                            }
                            , {
                                once: true
                            });

                            wrap.replaceChildren(el);

                            // Safety fallback in case load is slow or inconsistent
                            loaderSafetyTimer = setTimeout(done, 4500);
                        }
                        );
                    }
                    );

                    return false;
                }

                function closeOverlay() {
                    openToken += 1;
                    clearLoaderTimers();

                    overlay.hidden = true;
                    document.documentElement.classList.remove('no-scroll');

                    wrap.replaceChildren();
                    if (loadingEl) {
                        loadingEl.classList.remove('is-visible', 'is-hidden');
                    }

                    window.removeEventListener('keydown', escClose);
                    playBtn?.focus();
                }

                function escClose(e) {
                    if (e.key === 'Escape')
                        closeOverlay();
                }

                ['playBtn', 'mobileBtn', 'heroImgBtn'].forEach(id => {
                    const btn = document.getElementById(id);
                    if (!btn)
                        return;

                    btn.addEventListener('click', (e) => {
                        e.preventDefault();
                        e.stopPropagation();
                        e.stopImmediatePropagation();
                        openOverlay(e.currentTarget);
                    }
                    , true);
                }
                );

                closeBtn?.addEventListener('click', (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    closeOverlay();
                }
                );

                overlay?.addEventListener('click', (e) => {
                    if (e.target === overlay)
                        closeOverlay();
                }
                );

                window.addEventListener('message', (e) => {
                    try {
                        const data = typeof e.data === 'string' ? JSON.parse(e.data) : e.data;
                        if (data && (data.type === 'xogx:closeOverlay' || data.action === 'xogx:closeOverlay')) {
                            closeOverlay();
                        }
                    } catch {}
                }
                );

                window.__ov_open = openOverlay;
            }
            )();
        </script>
        <script>
            /* Changelog toggle (unchanged) */
            (function() {
                const shortEl = document.getElementById('changelogShort');
                const tpl = document.getElementById('fullChangelogTpl');
                const btn = document.getElementById('toggleChangelog');
                if (!shortEl || !tpl || !btn)
                    return;

                const shortHTML = shortEl.innerHTML.trim();
                const fullHTML = (tpl.content && tpl.content.firstElementChild) ? tpl.content.firstElementChild.outerHTML : tpl.innerHTML;

                if (!fullHTML || !fullHTML.trim()) {
                    btn.style.display = 'none';
                    return;
                }

                let showingFull = false;
                btn.addEventListener('click', function() {
                    if (!showingFull) {
                        shortEl.innerHTML = fullHTML;
                        btn.textContent = 'Show less';
                        btn.setAttribute('aria-expanded', 'true');
                        showingFull = true;
                    } else {
                        shortEl.innerHTML = shortHTML;
                        btn.textContent = 'Show full changelog';
                        btn.setAttribute('aria-expanded', 'false');
                        showingFull = false;
                    }
                });
            }
            )();
        </script>
