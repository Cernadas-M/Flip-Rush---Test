                <script>
                    /* store for recent games */
                    (function(w) {
                        const KEY = 'bubblebox_recent_v1'
                          , MAX = 12;
                        function read() {
                            try {
                                const arr = JSON.parse(localStorage.getItem(KEY) || '[]');
                                return Array.isArray(arr) ? arr.filter(n => Number.isInteger(n) && n > 0) : []
                            } catch {
                                return []
                            }
                        }
                        function write(arr) {
                            try {
                                localStorage.setItem(KEY, JSON.stringify(arr.slice(0, MAX)))
                            } catch {}
                        }
                        function add(id) {
                            id = Number(id);
                            if (!Number.isInteger(id) || id <= 0)
                                return;
                            const list = read().filter(n => n !== id);
                            list.unshift(id);
                            write(list);
                            console.log('[recent] added', id, '->', list)
                        }
                        function list() {
                            return read()
                        }
                        function clear() {
                            localStorage.removeItem(KEY)
                        }
                        w.BUBBLEBOXRecent = {
                            add,
                            list,
                            clear,
                            KEY
                        }
                    }
                    )(window)
                </script>
