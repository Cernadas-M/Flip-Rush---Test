        <script>
            const yearEl = document.getElementById('year');
            if (yearEl)
                yearEl.textContent = new Date().getFullYear();
            const hamburger = document.getElementById('hamburger');
            const drawer = document.getElementById('drawer');
            if (hamburger && drawer) {
                hamburger.addEventListener('click', () => {
                    const open = drawer.classList.toggle('open');
                    hamburger.setAttribute('aria-expanded', open ? 'true' : 'false')
                }
                );
                window.addEventListener('resize', () => {
                    if (window.innerWidth > 900 && drawer.classList.contains('open')) {
                        drawer.classList.remove('open');
                        hamburger.setAttribute('aria-expanded', 'false')
                    }
                }
                )
            }
            (function populateDrawer() {
                const drawer = document.getElementById('drawer');
                const drawerWrap = drawer?.querySelector('.drawer-wrap');
                if (!drawer || !drawerWrap)
                    return;
                const autofill = (drawer.dataset.autofill || '').trim();
                if (!autofill)
                    return;
                const wants = new Set(autofill.split(/[\s,]+/).filter(Boolean));
                const existingHrefs = new Set(Array.from(drawerWrap.querySelectorAll('a[href]')).map(a => a.getAttribute('href')));
                const makeLabel = (txt) => {
                    const lab = document.createElement('div');
                    lab.className = 'group-label';
                    lab.textContent = txt;
                    return lab
                }
                ;
                const addLink = (href, text) => {
                    if (!href || existingHrefs.has(href))
                        return !1;
                    const a = document.createElement('a');
                    a.href = href;
                    a.textContent = text.trim();
                    drawerWrap.appendChild(a);
                    existingHrefs.add(href);
                    return !0
                }
                ;
                if (wants.has('nav')) {
                    const nav = document.querySelector('.nav');
                    if (nav) {
                        const links = nav.querySelectorAll('a[href]:not([data-noshow]):not(.no-drawer)');
                        let added = 0;
                        links.forEach(a => {
                            added += addLink(a.getAttribute('href'), a.textContent) ? 1 : 0
                        }
                        );
                        if (added)
                            drawerWrap.prepend(makeLabel('NAVIGATION'));
                    }
                }
                if (wants.has('side')) {
                    const side = document.querySelector('.side');
                    if (side) {
                        const anchors = side.querySelectorAll('a.item[href]:not([data-noshow]):not(.no-drawer)');
                        let added = 0;
                        anchors.forEach(a => {
                            const label = a.querySelector('.label');
                            const text = (label ? label.textContent : a.textContent);
                            added += addLink(a.getAttribute('href'), text) ? 1 : 0
                        }
                        );
                        if (added)
                            drawerWrap.appendChild(makeLabel('SIDEBAR'));
                    }
                }
            }
            )();
            document.querySelector('#drawer')?.addEventListener('click', (e) => {
                if (e.target.matches('a[href]')) {
                    const drawer = document.getElementById('drawer');
                    const hamburger = document.getElementById('hamburger');
                    drawer.classList.remove('open');
                    hamburger?.setAttribute('aria-expanded', 'false')
                }
            }
            );
            (function() {
                const form = document.getElementById('site-search');
                if (!form)
                    return;
                const input = form.querySelector('.search-input');
                const icon = form.querySelector('.icon');
                const kbd = form.querySelector('.kbd');
                form.addEventListener('submit', (e) => {
                    if (!input.value.trim()) {
                        e.preventDefault();
                        input.focus()
                    }
                }
                );
                if (icon) {
                    icon.style.cursor = 'pointer';
                    icon.addEventListener('click', () => {
                        if (input.value.trim())
                            form.submit();
                        else
                            input.focus()
                    }
                    )
                }
                if (kbd) {
                    kbd.addEventListener('click', () => input.focus())
                }
                window.addEventListener('keydown', (e) => {
                    if (e.key === '/' && !e.ctrlKey && !e.metaKey && !e.altKey) {
                        const tag = (e.target.tagName || '').toLowerCase();
                        const editable = e.target.isContentEditable || tag === 'input' || tag === 'textarea' || tag === 'select';
                        if (!editable) {
                            e.preventDefault();
                            input.focus()
                        }
                    }
                }
                )
            }
            )();
        </script>
        <script>
            ( () => {
                const slotPx = el => Math.max(1, Math.round((el.closest('.thumb') || el).clientWidth));
                const usesWDescriptors = srcset => /\s\d+w(?:\s|$)/.test(srcset || '');
                const pickedWidth = img => {
                    const file = (img.currentSrc || img.src || '').split('/').pop();
                    const m = file.match(/-(\d+)x/);
                    return m ? +m[1] : img.naturalWidth || 0
                }
                ;
                const forceReselect = img => {
                    const ss = img.srcset;
                    img.srcset = '';
                    requestAnimationFrame( () => {
                        img.srcset = ss
                    }
                    )
                }
                ;
                const promote = pic => {
                    if (pic.__rpic)
                        return;
                    pic.__rpic = !0;
                    const img = pic.querySelector('img');
                    if (!img)
                        return;
                    let anyW = !1;
                    pic.querySelectorAll('source').forEach(s => {
                        if (s.dataset.srcset) {
                            if (usesWDescriptors(s.dataset.srcset))
                                anyW = !0;
                            s.srcset = s.dataset.srcset;
                            delete s.dataset.srcset
                        }
                    }
                    );
                    if (img.dataset.srcset) {
                        if (usesWDescriptors(img.dataset.srcset))
                            anyW = !0;
                        img.srcset = img.dataset.srcset;
                        delete img.dataset.srcset
                    }
                    if (img.dataset.src) {
                        img.src = img.dataset.src;
                        delete img.dataset.src
                    }
                    if (anyW)
                        img.sizes = slotPx(img) + 'px';
                    else
                        img.removeAttribute('sizes');
                    requestAnimationFrame( () => {
                        const need = Math.round(slotPx(img) * devicePixelRatio);
                        const have = pickedWidth(img);
                        if ((have && have > need * 1.25) || (have && have < need * 0.85)) {
                            forceReselect(img)
                        }
                    }
                    );
                    if (anyW) {
                        const ro = new ResizeObserver( () => {
                            const wanted = slotPx(img) + 'px';
                            if (img.sizes !== wanted) {
                                img.sizes = wanted;
                                forceReselect(img)
                            }
                        }
                        );
                        ro.observe(img.closest('.thumb') || img)
                    }
                }
                ;
                const io = new IntersectionObserver( (entries) => {
                    for (const e of entries)
                        if (e.isIntersecting) {
                            promote(e.target);
                            io.unobserve(e.target)
                        }
                }
                ,{
                    rootMargin: '400px'
                });
                document.querySelectorAll('picture.js-rpic').forEach(pic => io.observe(pic));
                new MutationObserver(muts => {
                    for (const m of muts) {
                        m.addedNodes.forEach(n => {
                            if (n.nodeType !== 1)
                                return;
                            if (n.matches?.('picture.js-rpic'))
                                io.observe(n);
                            else
                                n.querySelectorAll?.('picture.js-rpic').forEach(p => io.observe(p))
                        }
                        )
                    }
                }
                ).observe(document.body, {
                    childList: !0,
                    subtree: !0
                })
            }
            )();
        </script>
