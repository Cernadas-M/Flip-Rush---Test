        <script>
            /* Legacy inline onclick() shim — delegates to the real opener if present */
            window.__ov = function(el, evt) {
                try {
                    if (evt) {
                        evt.preventDefault();
                        evt.stopPropagation();
                        evt.stopImmediatePropagation();
                    }
                    if (typeof window.__ov_open === 'function')
