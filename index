                    const a = e.target.closest('a[href]');
                    if (!a || e.defaultPrevented)
                        return;
                    if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || e.button !== 0)
                        return;
                    if (a.hasAttribute('download') || (a.target && a.target !== '_self'))
